# Step 1: Base image with PyTorch (CPU version)
FROM pytorch/pytorch:latest

# Step 2: Install additional dependencies (if any)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    python3-dev \
    python3-pip \
    python3-setuptools \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install required Python packages
RUN pip install jupyter wandb flask flask-httpauth pandas numpy joblib scikit-learn==1.2.0 boto3

# For CoGNN
RUN pip install torch==2.1.0 torchvision==0.16.0 torchaudio==2.1.0 --index-url https://download.pytorch.org/whl/cu118
RUN pip install torch_scatter torch_sparse torch_cluster torch_spline_conv -f https://data.pyg.org/whl/torch-2.1.0+cu118.html
RUN pip install torch-geometric==2.3.0
RUN pip install torchmetrics ogb rdkit matplotlib

# Copy the entire project directory (uncomment if needed)
COPY ./src /app

# Set the working directory
WORKDIR /app

# CMD instead of ENTRYPOINT to allow the passing of arguments to inference.py
ENTRYPOINT ["python", "/app/inference.py"]

