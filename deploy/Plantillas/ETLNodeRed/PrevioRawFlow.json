  {
    "id": "procPrepPrevioXXXXXXXXXX",
    "type": "function",
    "name": "Procesado y Preparación",
    "func": "// Obtenemos el string con la lista de tuplas\nlet str = msg.payload;\n// Reemplazar paréntesis por corchetes para simular JSON válido\nstr = str.replace(/\\(/g, '[').replace(/\\)/g, ']');\n// Reemplazar comillas simples por comillas dobles\nstr = str.replace(/'/g, '\"');\n// Reemplazar valores tipo Python por los válidos en JSON/JS\nstr = str.replace(/\\bNone\\b/g, 'null');\nstr = str.replace(/\\bTrue\\b/g, 'true');\nstr = str.replace(/\\bFalse\\b/g, 'false');\nlet data;\ntry { data = JSON.parse(str); } catch (err) {\n  node.error(\"Error al convertir a JSON\", err);\n  return null;\n}\nmsg.payload = data;\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
