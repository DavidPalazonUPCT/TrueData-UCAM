  "id": "asignarURLPrevioXXXXXXXXXX",
  "type": "function",
  "name": "Asignar URL Destino Niveles Criticidad",
  "func": "// Obtener el diccionario global\nlet diccionarioAccess = global.get(\"diccionarioAccess\") || {};\nlet claveBuscada = msg.payload[\"DeviceName\"];\n\nif (diccionarioAccess.hasOwnProperty(claveBuscada)) {\n    let token = diccionarioAccess[claveBuscada].token;\n    msg.URL = \"ROOT_ThingsBoard/api/v1/\" + token + \"/telemetry\";\n} else {\n    // Fallback al token de XXXXXXXXXX Control (inyectado por el script previamente)\n    msg.URL = \"ROOT_ThingsBoard/api/v1/TOKEN_CONTROL/telemetry\";\n}\nreturn msg;",
