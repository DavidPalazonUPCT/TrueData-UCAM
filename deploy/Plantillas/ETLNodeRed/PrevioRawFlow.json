    "type": "function",
    "name": "Incluir Nombre Repositorio",
    "func": "msg.TOKEN = flow.get('TOKEN');\nmsg.nombre = msg.payload['DeviceName'];\nmsg.payload = { nombreNiv: msg.nombre };\nlet diccionarioAccess = global.get('diccionarioAccess') || {};\nmsg.continuar = 'SI';\nif (diccionarioAccess.hasOwnProperty(msg.nombreNiv)) {\n  if (diccionarioAccess[msg.nombreNiv].hasOwnProperty('deviceId')) {\n    if (diccionarioAccess[msg.nombreNiv].hasOwnProperty('token')) {\n      return null;\n    }\n  }\n}\nreturn msg;",
