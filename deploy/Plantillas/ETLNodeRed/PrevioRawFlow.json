  {
    "id": "updDictPrevioXXXXXXXXXX",
    "type": "function",
    "name": "Actualizar DICT TOKENS",
    "func": "let p={}; try{p=JSON.parse(msg.payload)}catch(e){}\nlet URL = 'ROOT_ThingsBoard/api/v1/' + p.credentialsId + '/telemetry';\nlet deviceId = p?.deviceId?.id;\nlet accessToken = p?.credentialsId;\nmsg.payload = { deviceId: deviceId, url: URL };\nmsg.deviceId = deviceId; msg.ceredentiaslId = accessToken; msg.URL = URL;\nlet dic = global.get('diccionarioAccess') || {};\nfor (let nombre in dic){ if(dic[nombre].deviceId===deviceId){ dic[nombre].token=accessToken; break; }}\nglobal.set('diccionarioAccess', dic);\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
